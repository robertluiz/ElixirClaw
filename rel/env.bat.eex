@echo off
REM ElixirClaw Windows Release Environment Setup
REM ------------------------------------------------
REM This file is evaluated when starting the release on Windows.
REM Uncomment and set the variables you need for your deployment.
REM Do NOT commit this file with real secrets.

REM ----------------------------------------------------------------
REM LLM Provider API Keys (at least one is required)
REM ----------------------------------------------------------------

REM OpenAI
REM SET OPENAI_API_KEY=your-openai-key-here

REM Anthropic Claude
REM SET ANTHROPIC_API_KEY=your-anthropic-key-here

REM OpenRouter (supports many models via a single API)
REM SET OPENROUTER_API_KEY=your-openrouter-key-here

REM ----------------------------------------------------------------
REM Optional: Messaging Channel Tokens
REM ----------------------------------------------------------------

REM Telegram Bot
REM SET TELEGRAM_BOT_TOKEN=your-telegram-token

REM Discord Bot
REM SET DISCORD_BOT_TOKEN=your-discord-token

REM ----------------------------------------------------------------
REM Optional: GitHub Copilot / Codex OAuth Credentials
REM ----------------------------------------------------------------

REM SET CODEX_CLIENT_ID=your-client-id
REM SET CODEX_CLIENT_SECRET=your-client-secret

REM ----------------------------------------------------------------
REM Optional: Database and Skills paths
REM ----------------------------------------------------------------

REM Override the default SQLite database path
REM SET ELIXIR_CLAW_DATABASE_PATH=C:\ProgramData\ElixirClaw\data.db

REM Override the skills directory path
REM SET ELIXIR_CLAW_SKILLS_DIR=C:\ProgramData\ElixirClaw\skills

REM ----------------------------------------------------------------
REM Optional: Release node name and cookie (for clustering)
REM ----------------------------------------------------------------

REM SET RELEASE_NODE=elixir_claw@127.0.0.1
REM SET RELEASE_COOKIE=some-random-secret-cookie
