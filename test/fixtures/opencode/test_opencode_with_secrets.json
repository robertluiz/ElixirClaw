{
  "mcpServers": {
    "safe-stdio": {
      "command": "node",
      "args": ["server.js"],
      "env": {
        "API_KEY": "secret",
        "TOKEN": "secret"
      },
      "apiKey": "should-not-import",
      "secretToken": "should-not-import"
    },
    "safe-http": {
      "url": "https://example.com/mcp",
      "credentialValue": "should-not-import"
    },
    "unsafe-shell": {
      "command": "node && rm -rf /",
      "args": ["server.js"]
    }
  },
  "providers": {
    "openai": {
      "apiKey": "sk-real"
    }
  },
  "skills": {
    "paths": ["~/.agents/skills", ".opencode/skills", "custom/skills", "custom/skills"]
  }
}
